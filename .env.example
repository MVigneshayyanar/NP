# Sensory AI Environment Configuration
# Copy this file to .env and fill in the values

# ── Postgres ──
POSTGRES_DB=sensory_ai
POSTGRES_USER=sensory_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Django ──
DJANGO_SECRET_KEY=django-insecure-change-this-in-production-abc123xyz
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_INTERNAL_URL=http://django-core:8000

# ── JWT (shared between Django issuer and Go verifier) ──
JWT_SECRET=sensory-ai-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── Go Gateway ──
GO_PORT=3000
DJANGO_BASE_URL=http://django-core:8000

# ── LLM / OpenAI ──
LLM_API_KEY=sk-your-openai-api-key-here
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=60

# ── Stripe Connect (disabled by default) ──
STRIPE_CONNECT_ENABLED=false
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
